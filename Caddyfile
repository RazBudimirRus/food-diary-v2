# Food Diary V2 — Caddy reverse proxy (Phase 6)
# TLS: wildcard cert — mount certs to /etc/ssl/razbudimir in container
# DOMAIN must be set in .env — no hardcoded fallback (Caddy will fail fast if missing)

{
	# JSON access logs
	log {
		output file /var/log/caddy/access.log
		format json
	}
}

{$DOMAIN} {
	tls /etc/ssl/razbudimir/fullchain.pem /etc/ssl/razbudimir/privkey.pem

	reverse_proxy api:5000

	encode gzip zstd

	header {
		# HSTS — only effective over HTTPS
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	log {
		output file /var/log/caddy/food_diary.log
		format json
	}
}
