# Food Diary V2 — Caddy reverse proxy (Phase 6)
# TLS: wildcard *.razbudimir.com — mount certs to /etc/ssl/razbudimir in container
# DOMAIN env var (default: fooddiary.razbudimir.com) — see docker-compose.yml

{
	# JSON access logs
	log {
		output file /var/log/caddy/access.log
		format json
	}
}

{$DOMAIN:fooddiary.razbudimir.com} {
	tls /etc/ssl/razbudimir/fullchain.pem /etc/ssl/razbudimir/privkey.pem

	reverse_proxy api:5000 {
		# Phase 7 — Cloudflare passes real client IP; API reads CF-Connecting-IP
		header_up CF-Connecting-IP {http.request.header.CF-Connecting-IP}
	}

	encode gzip zstd

	header {
		# HSTS — only effective over HTTPS
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	log {
		output file /var/log/caddy/food_diary.log
		format json
	}
}
