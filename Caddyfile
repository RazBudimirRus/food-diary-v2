# Food Diary V2 — Caddy reverse proxy (Phase 6)
# TLS: wildcard cert — mount certs to /etc/ssl/razbudimir in container
# DOMAIN must be set in .env — no hardcoded fallback (Caddy will fail fast if missing)

{
	# JSON access logs
	log {
		output file /var/log/caddy/access.log
		format json
	}
}

{$DOMAIN} {
	tls /etc/ssl/razbudimir/fullchain.pem /etc/ssl/razbudimir/privkey.pem

	reverse_proxy api:5000

	encode gzip zstd

	header {
		# Security headers (Phase 26.3)
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# Remove server identity
		-Server
		-X-Powered-By
	}

	log {
		output file /var/log/caddy/food_diary.log
		format json
	}
}
