# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Public URL (Phase 6 — HTTPS) ─────────────────────────────────────────────
# ⚠ ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ: замени your-domain.example.com на свой домен (все три строки ниже).
# DNS A-record: your-domain.example.com → IP сервера
DOMAIN=your-domain.example.com
PUBLIC_URL=https://your-domain.example.com

# CORS whitelist (comma-separated). Должно совпадать с DOMAIN выше.
ALLOWED_ORIGINS=https://your-domain.example.com

# Behind Caddy reverse proxy (set 1 in production docker-compose)
TRUST_PROXY=1

# Phase 4 admin bootstrap: existing username to promote to admin at startup
# ADMIN_BOOTSTRAP_USERNAME=your_username

# Secure auth cookies — auto true when NODE_ENV=production; override for local HTTP:
# SQLite (Phase 3) — path inside container; host mount: /srv/foodbot/data
# SQLITE_DB_PATH=data.db

# Backup retention count (scripts/backup.sh)
BACKUP_RETENTION=30

# ── Security — ОБЯЗАТЕЛЬНО изменить перед деплоем! ───────────────────────────

# JWT secret — любая длинная случайная строка (мин. 32 символа)
# Генерация: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT TTL — короткий access token, хранится только в памяти React
JWT_EXPIRES_IN=30m

# Refresh token TTL — хранится в БД как SHA-256 hash и в httpOnly cookie
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Max-Age для refresh token (секунды), 7 дней = 604800
REFRESH_COOKIE_MAX_AGE=604800

# Idle timeout фронтенд — предупреждение (минуты)
SESSION_IDLE_WARNING_MIN=25
VITE_SESSION_IDLE_WARNING_MIN=25

# Idle timeout фронтенд — принудительный выход (минуты)
SESSION_IDLE_TIMEOUT_MIN=30
VITE_SESSION_IDLE_TIMEOUT_MIN=30

# Ключ шифрования секретов в БД (AES-256-GCM)
# Генерация: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── AI / КБЖУ анализ ─────────────────────────────────────────────────────────

# DeepSeek API ключ для расчёта КБЖУ по описанию еды
# Получить: https://platform.deepseek.com/api_keys
# Если не задан — кнопка «Рассчитать КБЖУ» не отображается
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Admin dashboard usage alerts
DEEPSEEK_DAILY_TOKEN_LIMIT=100000
DEEPSEEK_INPUT_USD_PER_M_TOKENS=0.27
DEEPSEEK_OUTPUT_USD_PER_M_TOKENS=1.10

# ── Email / password reset (Phase 5) ─────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=Food Diary <noreply@your-domain.example.com>

# ── VK Object Storage (Phase 23 — фото блюд) ─────────────────────────────────
# Endpoint VK Cloud S3-compatible хранилища
VK_S3_ENDPOINT=https://hb.vkcs.cloud
VK_S3_REGION=ru-msk
VK_S3_BUCKET=food-diary-photos
# Ключи доступа — создать в консоли VK Cloud → Object Storage → Ключи доступа
VK_S3_ACCESS_KEY=your_vk_s3_access_key
VK_S3_SECRET_KEY=your_vk_s3_secret_key
# Ограничения фотографий
PHOTO_MAX_SIZE_MB=10
PHOTO_MAX_PER_USER=500

# ── Web Push / VAPID (Phase 15 — уведомления доктора) ────────────────────────
# Генерация ключей: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your@email.com
