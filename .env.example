# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Public URL (Phase 6 — HTTPS) ─────────────────────────────────────────────
# DNS A-record: fooddiary.razbudimir.com → VPS IP
DOMAIN=fooddiary.razbudimir.com
PUBLIC_URL=https://fooddiary.razbudimir.com

# Behind Caddy reverse proxy (set 1 in production docker-compose)
TRUST_PROXY=1

# Secure auth cookies — auto true when NODE_ENV=production; override for local HTTP:
# SQLite (Phase 3) — path inside container; host mount: /srv/foodbot/data
# SQLITE_DB_PATH=data.db

# Backup retention count (scripts/backup.sh)
BACKUP_RETENTION=30

# ── Security — ОБЯЗАТЕЛЬНО изменить перед деплоем! ───────────────────────────

# JWT secret — любая длинная случайная строка (мин. 32 символа)
# Генерация: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT TTL — время жизни токена
JWT_EXPIRES_IN=7d

# Ключ шифрования секретов в БД (AES-256-GCM)
# Генерация: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── AI / КБЖУ анализ ─────────────────────────────────────────────────────────

# DeepSeek API ключ для расчёта КБЖУ по описанию еды
# Получить: https://platform.deepseek.com/api_keys
# Если не задан — кнопка «Рассчитать КБЖУ» не отображается
DEEPSEEK_API_KEY=your_deepseek_api_key_here
