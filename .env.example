# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Security — ОБЯЗАТЕЛЬНО изменить перед деплоем! ───────────────────────────

# JWT secret — любая длинная случайная строка (мин. 32 символа)
# Генерация: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT TTL — время жизни токена
JWT_EXPIRES_IN=7d

# Ключ шифрования секретов в БД (AES-256-GCM)
# Генерация: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
